# ============================================================
# Dofus Bot — configuration env
# Copy to `.env` and fill in. NEVER commit .env.
# ============================================================

# ---------- Game ----------
DOFUS_WINDOW_TITLE=Dofus 2.64
DOFUS_EXECUTABLE_PATH=C:\Program Files\Dofus\Dofus.exe

# ---------- External tools ----------
TESSERACT_PATH=C:\Program Files\Tesseract-OCR\tesseract.exe
TESSERACT_LANG=fra
# Optional: custom tessdata dir (if fra.traineddata is not in Tesseract's bundled tessdata)
# TESSDATA_DIR=./data/tessdata

# ---------- Persistence ----------
DB_PATH=./data/bot.sqlite3
MAPS_GRAPH_PATH=./data/maps_graph.json
LOG_DIR=./logs
SCREENSHOTS_DIR=./screenshots

# ---------- Calibration ----------
CALIBRATION_DATA_DIR=./data/calibration

# ---------- YOLO (optional) ----------
# Leave empty to disable YOLO. Set to a .pt model path once trained.
# Requires: pip install "ultralytics>=8.3.0"
YOLO_MODEL_PATH=
YOLO_CONFIDENCE_THRESHOLD=0.5

# ---------- OCR ----------
OCR_LANG=fra    # Tesseract language pack: fra | eng | fra+eng

# ---------- Discord (optional) ----------
DISCORD_ENABLED=false
DISCORD_TOKEN=
DISCORD_GUILD_ID=
DISCORD_ALLOWED_USER_IDS=   # comma-separated, e.g. 12345,67890

# ---------- Bot defaults ----------
DEFAULT_JOB=lumberjack
DEFAULT_ZONE=bonta_forest_sud
INVENTORY_FULL_THRESHOLD=0.90
STOP_LOSS_XP_PER_HOUR=0        # 0 disables
HUMANIZE_CLICKS=true

# ---------- Logging ----------
LOG_LEVEL=INFO                 # DEBUG | INFO | WARNING | ERROR
LOG_ROTATION_MB=50
LOG_RETENTION_DAYS=14
